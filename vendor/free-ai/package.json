    "prompt-promote": "node scripts/promote_prompt_variant.js",
    "prompt-rollback": "node scripts/rollback_prompt_variant.js",
    "bootstrap-host": "node scripts/bootstrap_host_project.js --dry-run",
    "admin-report": "node scripts/admin_status_report.js",
    "training-cycle": "node scripts/run_training_cycle.js",
    "training-report": "node scripts/training_status_report.js",
